rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isSuper() {
      return signedIn()
        && (
          profile().rol in ['superadmin', 'superAdmin', 'SuperAdmin', 'Superadmin']
          || profile().role in ['superadmin', 'superAdmin', 'SuperAdmin', 'Superadmin']
          || profile().tipoUsuario in ['superadmin', 'superAdmin', 'SuperAdmin', 'Superadmin']
        );
    }
    function isAdmin() {
      return signedIn()
        && (
          profile().rol in ['admin', 'superadmin', 'Admin', 'SuperAdmin', 'Superadmin', 'superAdmin']
          || profile().role in ['admin', 'superadmin', 'Admin', 'SuperAdmin', 'Superadmin', 'superAdmin']
          || profile().tipoUsuario in ['admin', 'superadmin', 'Admin', 'SuperAdmin', 'Superadmin', 'superAdmin']
        );
    }
    function canManagePayroll() {
      return signedIn()
        && (
          isAdmin()
          || profile().rol in ['gerente', 'Gerente', 'manager', 'Manager', 'administrador', 'Administrador', 'administradora', 'Administradora']
          || profile().role in ['gerente', 'Gerente', 'manager', 'Manager', 'administrador', 'Administrador', 'administradora', 'Administradora']
          || profile().tipoUsuario in ['gerente', 'Gerente', 'manager', 'Manager', 'administrador', 'Administrador', 'administradora', 'Administradora']
        );
    }

    match /empleados/{document=**} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /horarios/{document=**} {
      allow read: if signedIn();
      allow create, update: if canManagePayroll();
      allow delete: if isAdmin();
    }

    match /apartados/{document=**} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isSuper();
    }

    match /abonos/{document=**} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isSuper();
    }

    match /{document=**} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isSuper();
    }
  }
}
